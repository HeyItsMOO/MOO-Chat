# ──────────────────────────────────────────────────────────────
# MOO Chat — environment variables
# Copy this file to ".env" and fill in the values.
# ──────────────────────────────────────────────────────────────

# Local dev uses SQLite (zero setup). For production, swap to a Neon/Supabase
# Postgres URL and change the provider in prisma/schema.prisma to "postgresql".
DATABASE_URL="file:./dev.db"

# Your ONE central Anthropic API key. The whole platform bills against this key
# and meters usage per tenant. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# Secret used to sign session cookies (any long random string).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-string"

# The public origin where this app is hosted. Used to build the embed snippet.
# Local dev: http://localhost:3000   Production: https://app.yourdomain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Stage 2 (billing) — PayPal Subscriptions ──
# Create REST API credentials at https://developer.paypal.com/dashboard/applications
PAYPAL_ENV="sandbox"          # sandbox | live
PAYPAL_CLIENT_ID=""
PAYPAL_SECRET=""
# Set after creating a webhook (→ /api/webhooks/paypal) in the PayPal dashboard.
PAYPAL_WEBHOOK_ID=""
# Filled by `npm run paypal:setup` — the plan id for each paid tier.
PAYPAL_PLAN_STARTER=""
PAYPAL_PLAN_PRO=""
PAYPAL_PLAN_BUSINESS=""

# ── Stage 3 (email) — leave blank to log emails to the console instead ──
RESEND_API_KEY=""
EMAIL_FROM="MOO Chat <hello@yourdomain.com>"
