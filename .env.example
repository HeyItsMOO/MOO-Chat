# ──────────────────────────────────────────────────────────────
# ChatMOO — environment variables
# Copy this file to ".env" and fill in the values.
# ──────────────────────────────────────────────────────────────

# PostgreSQL connection string. Use a free Neon/Supabase/Vercel Postgres branch,
# or a local Postgres. The build runs `prisma db push` to create the tables.
#   Neon/Supabase format: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/moochat?schema=public"

# Your ONE central Anthropic API key. The whole platform bills against this key
# and meters usage per tenant. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# Secret used to sign session cookies (any long random string).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-string"

# The public origin where this app is hosted. Used to build the embed snippet.
# Local dev: http://localhost:3000   Production: https://app.yourdomain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Stage 2 (billing) — PayPal Subscriptions ──
# Create REST API credentials at https://developer.paypal.com/dashboard/applications
PAYPAL_ENV="sandbox"          # sandbox | live
PAYPAL_CLIENT_ID=""
PAYPAL_SECRET=""
# Set after creating a webhook (→ /api/webhooks/paypal) in the PayPal dashboard.
PAYPAL_WEBHOOK_ID=""
# Filled by `npm run paypal:setup` — the plan id for each paid tier.
# Monthly:
PAYPAL_PLAN_STARTER=""
PAYPAL_PLAN_PRO=""
PAYPAL_PLAN_BUSINESS=""
# Yearly (10× monthly = 2 months free). Also filled by `npm run paypal:setup`.
PAYPAL_PLAN_STARTER_YEARLY=""
PAYPAL_PLAN_PRO_YEARLY=""
PAYPAL_PLAN_BUSINESS_YEARLY=""

# ── WHMCS provisioning module ──
# Shared secret the WHMCS module uses to call this app's provisioning API
# (POST /api/provisioning). Generate one with: openssl rand -hex 32
# Leave blank to disable the provisioning API. See whmcs/modules/servers/chatmoo/README.md
PROVISIONING_API_KEY=""

# ── Referral / affiliate program ──
# Flat commission (in cents) earned per referral that converts to a paying
# customer. Default 2000 = A$20.00. Shown to referrers on /dashboard/referrals.
REFERRAL_COMMISSION_CENTS="2000"

# ── Stage 3 (email) — leave blank to log emails to the console instead ──
RESEND_API_KEY=""
EMAIL_FROM="ChatMOO <Holler@HeyItsMOO.com>"

# ── Seed accounts (used by `npm run db:seed`) ──
# IMPORTANT: set these before seeding PRODUCTION so you don't ship default
# credentials. Leave blank locally to use the dev demo logins.
SEED_ADMIN_EMAIL="Holler@HeyItsMOO.com"
SEED_ADMIN_PASSWORD=""
SEED_DEMO_EMAIL=""
SEED_DEMO_PASSWORD=""

# Set to "1" in Vercel to run the seed automatically on every deploy (creates/
# refreshes your admin + the always-on ChatMOO site bot). Requires
# SEED_ADMIN_PASSWORD to be set. Leave unset to skip seeding on deploy.
SEED_ON_DEPLOY=""
