// ChatMOO — multi-tenant data model.
//
// Runs on PostgreSQL (Neon, Supabase, Vercel Postgres, or local Postgres).
// Set DATABASE_URL to your connection string, then sync the schema with
// `prisma db push` (what the Vercel build runs) or `prisma migrate` if you
// prefer versioned migrations.
//
// The schema is intentionally portable: statuses/roles are plain strings and
// JSON blobs are stored as strings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Accounts & people ───────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String   @default("")
  isSuperAdmin Boolean  @default(false) // platform owner (you) — sees all tenants
  createdAt    DateTime @default(now())

  memberships Membership[]
}

// A Tenant is one customer account ("store"). Everything is scoped to a tenant.
model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  websiteUrl  String   @default("")
  publicKey   String   @unique // used by the embed widget (safe to expose)
  plan        String   @default("free") // free | starter | pro | business
  status      String   @default("trialing") // trialing | active | past_due | suspended
  trialEndsAt DateTime?
  createdAt   DateTime @default(now())

  // Billing — PayPal Subscriptions (Stage 2)
  paypalSubscriptionId String?   @unique
  paypalPlanId         String?
  planRenewsAt         DateTime?
  // (Reserved, unused — kept for an optional future Stripe path.)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique

  // Promo / credits (see PromoCode). creditCents is a stored balance; the
  // discount window is an active percentage-off applied to the next subscription.
  creditCents     Int       @default(0)
  discountPercent Int       @default(0)
  discountUntil   DateTime?

  assistant      Assistant?
  memberships    Membership[]
  allowedDomains AllowedDomain[]
  conversations  Conversation[]
  leads          Lead[]
  usageCounters  UsageCounter[]
  promoRedemptions PromoRedemption[]
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      String   @default("owner") // owner | admin | agent
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
}

// ── The assistant's configuration (1:1 with a tenant) ───────────────

model Assistant {
  id       String @id @default(cuid())
  tenantId String @unique

  enabled Boolean @default(true)

  // Brand / appearance
  companyName    String @default("")
  headerTitle    String @default("AI Assistant")
  headerSubtitle String @default("")
  welcomeMessage String @default("Hi! How can I help you today?")
  // Newline-separated suggested questions (shown as chips).
  suggestedQuestions String @default("")
  primaryColor   String @default("#4f46e5")
  accentColor    String @default("#22c55e")
  position       String @default("right") // right | left
  launcherLabel  String @default("Chat with us")
  disclaimer     String @default("")
  showPoweredBy  Boolean @default(true)

  // Custom scripts (raw <script>/HTML) the tenant injects on their own site
  // alongside the widget — e.g. analytics, pixels, their own integrations.
  // Served via the widget config only on plans where features.customScripts is on.
  customScripts  String @default("")

  // Contact info surfaced in replies/fallbacks
  phone        String @default("")
  contactEmail String @default("")

  // AI behaviour
  model         String @default("claude-haiku-4-5-20251001")
  maxTokens     Int    @default(800)
  // The editable "brain" of the assistant.
  persona       String @default("")
  knowledgeBase String @default("")
  // Extra safety/behaviour rules appended to every system prompt.
  guardrails    String @default("")

  // Cost / abuse controls
  rateLimitPerHour Int @default(30)

  // Lead capture form (generalized from the InsureGroup quote form)
  leadFormEnabled     Boolean @default(true)
  leadFormTitle       String  @default("Request a quote")
  leadFormIntro       String  @default("Leave your details and we'll get back to you.")
  leadFormButtonLabel String  @default("Request a quote")
  leadFormSuccess     String  @default("Thanks — your details have been sent to our team. We'll be in touch shortly.")
  // JSON array of field definitions (see src/lib/leadform.ts).
  leadFormFields      String  @default("[]")
  // Where lead notifications are emailed (falls back to the tenant owner).
  leadNotifyEmail     String  @default("")

  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// Origins allowed to embed this tenant's widget. Empty = allow the tenant's
// own websiteUrl host only (set during onboarding).
model AllowedDomain {
  id       String @id @default(cuid())
  tenantId String
  domain   String // normalized host, e.g. "example.com"

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, domain])
  @@index([tenantId])
}

// ── Conversations & messages ────────────────────────────────────────

model Conversation {
  id           String   @id @default(cuid())
  tenantId     String
  sessionId    String
  status       String   @default("bot") // bot | waiting | live | closed
  agent        String   @default("")
  visitorName  String   @default("")
  visitorEmail String   @default("")
  pageUrl      String   @default("")
  ipHash       String   @default("")
  userAgent    String   @default("")
  msgCount     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([tenantId, sessionId])
  @@index([tenantId, updatedAt])
  @@index([tenantId, status])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String // user | assistant | agent | system
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// ── Leads (generalized quote requests) ──────────────────────────────

model Lead {
  id        String   @id @default(cuid())
  tenantId  String
  name      String   @default("")
  email     String   @default("")
  phone     String   @default("")
  pageUrl   String   @default("")
  // JSON string of all submitted fields.
  payload   String   @default("{}")
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

// ── Usage metering (one row per tenant per month) ───────────────────

model UsageCounter {
  id           String @id @default(cuid())
  tenantId     String
  period       String // "YYYY-MM"
  messageCount Int    @default(0)
  tokensIn     Int    @default(0)
  tokensOut    Int    @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, period])
  @@index([tenantId])
}

// ── Promo codes ─────────────────────────────────────────────────────
// One code can grant free time (extended trial or a comped plan), a percentage
// discount window, or account credit. Redeemed at signup, on the billing page,
// or applied by an admin. Each tenant can redeem a given code once.
model PromoCode {
  id              String   @id @default(cuid())
  code            String   @unique // stored UPPERCASE
  description     String   @default("")
  benefit         String   @default("free_days") // free_days | percent_off | credit
  planId          String   @default("") // comp target (free_days) / scope (optional)
  days            Int      @default(0) // free_days: trial/comp days
  percentOff      Int      @default(0) // percent_off: 1..100
  durationMonths  Int      @default(1) // percent_off: months the discount applies
  amountCents     Int      @default(0) // credit: amount in cents
  currency        String   @default("AUD")
  maxRedemptions  Int      @default(0) // 0 = unlimited
  redemptionCount Int      @default(0)
  expiresAt       DateTime?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  redemptions PromoRedemption[]
}

model PromoRedemption {
  id        String   @id @default(cuid())
  codeId    String
  tenantId  String
  userId    String   @default("")
  note      String   @default("") // snapshot of what was applied
  createdAt DateTime @default(now())

  code   PromoCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([codeId, tenantId])
  @@index([tenantId])
  @@index([codeId])
}

// ── Referrals / affiliate program ───────────────────────────────────

// A tenant's own shareable referral code. Kept in its own table (rather than a
// unique column on Tenant) so adding it is a pure additive migration — adding a
// unique constraint to the existing Tenant table trips `prisma db push`'s
// data-loss guard, which fails the non-interactive deploy. Allocated lazily the
// first time the tenant opens the "Refer & earn" page.
model ReferralCode {
  code      String   @id // the shareable code (primary key ⇒ unique)
  tenantId  String   @unique // one code per tenant
  createdAt DateTime @default(now())
}

// When a new tenant signs up via someone's referral code, we record a Referral
// for the referrer. It starts "pending" and becomes "earned" (a payable
// commission) once the referred tenant becomes a paying customer. The platform
// owner marks it "paid" from the admin once they've paid the affiliate out.
model Referral {
  id              String    @id @default(cuid())
  code            String // the referral code used at signup
  referrerId      String // tenant that earns the commission
  referredId      String    @unique // tenant that signed up (one referral each)
  referredName    String    @default("") // snapshot for the referrer's list
  status          String    @default("pending") // pending | earned | paid | void
  commissionCents Int       @default(0)
  currency        String    @default("AUD")
  createdAt       DateTime  @default(now())
  earnedAt        DateTime?
  paidAt          DateTime?

  @@index([referrerId])
  @@index([code])
  @@index([status])
}
